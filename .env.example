# ===========================================================================
# 필립 수영 예약 — 환경변수 예시
# 이 파일을 .env.local 로 복사해서 채워 넣으세요.
# 값이 없어도 앱은 인메모리(mock) 데이터로 정상 동작합니다.
# ===========================================================================

# Supabase 프로젝트 URL. 이 값이 있으면 앱은 Supabase를 데이터 저장소로 사용합니다.
# 비워두면 샘플 수영 강습 데이터가 담긴 인메모리 저장소로 동작합니다.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon(public) 키.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 관리자(스튜디오 운영자) 전화번호. 이 번호로 로그인하면 관리자 권한을 갖습니다.
# 데모 기본값: 010-0000-0000
ADMIN_PHONE=010-0000-0000
